{
  "name": "gg-manager-monorepo",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/admin",
    "apps/client"
  ],
  "scripts": {
    "server:dev": "npm --workspace apps/server run start:dev",
    "admin:dev": "npm --workspace apps/admin run dev",
    "client:dev": "npm --workspace apps/client run tauri:dev",
    "db:up": "npm --workspace apps/server run db:up",
    "smoke": "node apps/server/scripts/ws-smoke-test.js",
    "typecheck": "npm --workspace apps/server run typecheck && npm --workspace apps/admin run typecheck",
    "test": "npm --workspace apps/server test"
  }
}