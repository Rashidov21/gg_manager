generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MachineStatus {
  ONLINE
  OFFLINE
  ACTIVE
  RESERVED
  ERROR
  LOCKED
}

enum SessionStatus {
  ACTIVE
  PAUSED
  FINISHED
  EXPIRED
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
}

enum TariffType {
  HOURLY
  PACKAGE
  NIGHT
  BONUS
}

enum OperatorLogType {
  TOP_UP
  SESSION_START
  SESSION_EXTEND
  SESSION_STOP
  LOCK
  UNLOCK
  REBOOT
}

model Computer {
  id            String        @id @default(cuid())
  name          String
  ip            String
  mac           String
  status        MachineStatus
  lastSeenAt    DateTime?
  zone          String?
  warnCpuTemp   Int?
  warnGpuTemp   Int?
  warnRamUsage  Int?
  warnDiskUsage Int?
  createdAt     DateTime      @default(now())

  sessions   Session[]
  events     ClientEvent[]
  snapshots  HardwareSnapshot[]

  @@unique([ip])
  @@unique([mac])
  @@index([status])
}

model Account {
  id           String    @id @default(cuid())
  username     String    @unique
  balance      Decimal   @default(0) @db.Decimal(12, 2)
  bonusMinutes Int       @default(0)
  tier         String?
  createdAt    DateTime  @default(now())

  sessions     Session[]
  operatorLogs OperatorLog[]
}

model Tariff {
  id        String     @id @default(cuid())
  name      String
  type      TariffType
  price     Decimal    @db.Decimal(12, 2)
  minutes   Int
  startHour Int?
  endHour   Int?
  zone      String?

  sessions  Session[]

  @@index([type])
  @@index([zone])
}

model Session {
  id            String        @id @default(cuid())
  computerId    String
  accountId     String?
  tariffId      String
  status        SessionStatus
  startedAt     DateTime
  endsAt        DateTime
  pausedAt      DateTime?
  localRevision Int           @default(0)

  computer      Computer      @relation(fields: [computerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  account       Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  tariff        Tariff        @relation(fields: [tariffId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  operatorLogs  OperatorLog[]

  @@index([computerId])
  @@index([accountId])
  @@index([tariffId])
  @@index([status])
  @@index([startedAt])
}

model Operator {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())

  logs         OperatorLog[]

  @@index([role])
}

model OperatorLog {
  id          String          @id @default(cuid())
  type        OperatorLogType
  operatorId  String?
  accountId   String?
  sessionId   String?
  amount      Decimal?        @db.Decimal(12, 2)
  payload     Json?
  createdAt   DateTime        @default(now())

  operator    Operator?       @relation(fields: [operatorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  account     Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  session     Session?        @relation(fields: [sessionId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([type])
  @@index([operatorId])
  @@index([accountId])
  @@index([sessionId])
  @@index([createdAt])
}

model PromoCode {
  id           String   @id @default(cuid())
  code         String   @unique
  bonusPercent Int?
  bonusMinutes Int?
  expiresAt    DateTime?
  maxUses      Int?
  usedCount    Int      @default(0)
}

model ClientEvent {
  id        String   @id @default(cuid())
  computerId String
  type      String
  payload   Json
  syncState String
  createdAt DateTime @default(now())

  computer  Computer @relation(fields: [computerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([computerId])
  @@index([type])
  @@index([createdAt])
}

model HardwareSnapshot {
  id        String   @id @default(cuid())
  computerId String
  cpuUsage  Float?
  cpuTemp   Float?
  gpuTemp   Float?
  ramUsage  Float?
  diskUsage Float?
  createdAt DateTime @default(now())

  computer  Computer @relation(fields: [computerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([computerId])
  @@index([createdAt])
}

model License {
  id           String   @id @default(cuid())
  clubName     String
  licenseKey   String
  maxComputers Int
  expiresAt    DateTime
}

