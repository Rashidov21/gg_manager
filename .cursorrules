14. Prisma schema (commercial v1)
enum MachineStatus {
  ONLINE
  OFFLINE
  ACTIVE
  RESERVED
  ERROR
  LOCKED
}

enum SessionStatus {
  ACTIVE
  PAUSED
  FINISHED
  EXPIRED
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
}

enum TariffType {
  HOURLY
  PACKAGE
  NIGHT
  BONUS
}

model Computer {
  id            String   @id @default(cuid())
  name          String
  ip            String
  mac           String
  status        MachineStatus
  lastSeenAt    DateTime?
  zone          String?
  createdAt     DateTime @default(now())

  sessions      Session[]
  events        ClientEvent[]
  snapshots     HardwareSnapshot[]
}

model Account {
  id            String   @id @default(cuid())
  username      String   @unique
  balance       Decimal  @default(0)
  bonusMinutes  Int      @default(0)
  tier          String?
  createdAt     DateTime @default(now())

  sessions      Session[]
}

model Tariff {
  id          String      @id @default(cuid())
  name        String
  type        TariffType
  price       Decimal
  minutes     Int
  startHour   Int?
  endHour     Int?
  zone        String?

  sessions    Session[]
}

model Session {
  id             String        @id @default(cuid())
  computerId     String
  accountId      String?
  tariffId       String
  status         SessionStatus
  startedAt      DateTime
  endsAt         DateTime
  pausedAt       DateTime?
  localRevision  Int           @default(0)

  computer       Computer      @relation(fields: [computerId], references: [id])
  account        Account?      @relation(fields: [accountId], references: [id])
  tariff         Tariff        @relation(fields: [tariffId], references: [id])
}

model Operator {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  role          Role
  createdAt     DateTime @default(now())
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  bonusPercent  Int?
  bonusMinutes  Int?
  expiresAt     DateTime?
  maxUses       Int?
  usedCount     Int      @default(0)
}

model ClientEvent {
  id           String   @id @default(cuid())
  computerId   String
  type         String
  payload      Json
  syncState    String
  createdAt    DateTime @default(now())

  computer     Computer @relation(fields: [computerId], references: [id])
}

model HardwareSnapshot {
  id           String   @id @default(cuid())
  computerId   String
  cpuUsage     Float?
  cpuTemp      Float?
  gpuTemp      Float?
  ramUsage     Float?
  diskUsage    Float?
  createdAt    DateTime @default(now())

  computer     Computer @relation(fields: [computerId], references: [id])
}

model License {
  id            String   @id @default(cuid())
  clubName      String
  licenseKey    String
  maxComputers  Int
  expiresAt     DateTime
}
